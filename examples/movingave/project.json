{
  "toolsets": {
    "llvm": {
      "compiler": "clang",
      "linker": "lld",
      "compiler_flags": [
        "-O3",
        "-msse2",
        "-mfpmath=sse",
        "-Wno-incompatible-library-redeclaration"
      ],
      "linker_flags": [
        "/VERSION:21076.20053",
        "/HEAP:1048576,4096",
        "/STACK:1048576,4096",
        "/IGNORE:4006"
      ]
    },
    "vs2017": {
      "compiler": "cl",
      "linker": "link",
      "compiler_flags": [
        "/W3",
        "/nologo"
      ],
      "linker_flags": [
        "/VERSION:21076.20053",
        "/HEAP:1048576,4096",
        "/STACK:1048576,4096",
        "/NOLOGO"
      ]
    }
  },
  "targets": [
    {
      "name": "default",
      "toolset": "llvm",
      "output_dir": "",
      "output": "out/movingave.rta",
      "optimize": "3",
      "compile_only": false,
      "includes": null,
      "sources": [
        "movingave.c",
        "main.c"
      ],
      "libs": null,
      "defines": null,
      "flags": null
    },
    {
      "name": "avx2",
      "toolset": "llvm",
      "output_dir": "",
      "output": "out/movingave_avx2.rta",
      "optimize": "3",
      "compile_only": false,
      "includes": null,
      "sources": [
        "movingave.c",
        "main.c"
      ],
      "libs": null,
      "defines": null,
      "flags": [
        "-mavx2",
        "-mfma"
      ]
    }
  ]
}