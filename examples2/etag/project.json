{
  "toolsets": {
    "llvm": {
      "compiler": "clang",
      "linker": "lld",
      "compiler_flags": [
        "-Wno-visibility",
        "-Wno-microsoft-anon-tag"
      ],
      "linker_flags": [
        "/VERSION:21076.20053",
        "/HEAP:1048576,4096",
        "/STACK:1048576,4096",
        "/LIBPATH:$(RTEDGE)\\Library",
        "/LIBPATH:$(RTEDGE)\\Library\\Rt"
      ]
    },
    "vs2017": {
      "compiler": "cl",
      "linker": "link",
      "compiler_flags": [
        "/W3",
        "/nologo"
      ],
      "linker_flags": [
        "/VERSION:21076.20053",
        "/HEAP:1048576,4096",
        "/STACK:1048576,4096",
        "/NOLOGO"
      ]
    }
  },
  "targets": [
    {
      "name": "default",
      "toolset": "llvm",
      "output_dir": "out",
      "output": "etag.rta",
      "optimize": "2",
      "compile_only": false,
      "includes": [
        ".",
        "${RTEDGE}/Library",
        "${RTEDGE}/Library/Rt"
      ],
      "sources": [
        "etag.c",
        "inc.il",
        "out/inc_rtedge_glue.c",
        "../../rtedge/rtedgelink.c"
      ],
      "libs": [
        "eghgapi.lib"
      ],
      "defines": [
        "IL_USE_ETAG_RTEDGE"
      ],
      "flags": null
    }
  ]
}
