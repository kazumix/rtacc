{
  "toolsets": {
    "llvm": {
      "compiler": "clang",
      "linker": "lld",
      "compiler_flags": [
        "-Wno-visibility",
        "-Wno-microsoft-anon-tag"
      ],
      "linker_flags": [
        "/VERSION:21076.20053",
        "/HEAP:1048576,4096",
        "/STACK:1048576,4096",
        "/LIBPATH:$(RTEDGE)\\Library",
        "/LIBPATH:$(RTEDGE)\\Library\\Rt"
      ]
    }
  },
  "targets": [
    {
      "name": "default",
      "toolset": "llvm",
      "output_dir": "out",
      "output": "hugeplc.rta",
      "optimize": "0",
      "compile_only": false,
      "includes": [
        ".",
        "../IL",
        "$(RTEDGE)\\Library"
      ],
      "sources": [
        "main.c",
        "hugeplc_ascii2.IL",
        "out/hugeplc_ascii2.IL_rtedge_glue.c",
        "../../rtedge/rtedgelink.c"
      ],
      "libs": [
        "eghgapi.lib"
      ],
      "defines": [
        "IL_USE_ETAG_RTEDGE"
      ],
      "flags": null
    }
  ]
}
